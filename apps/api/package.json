{
  "name": "@wandr/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node --import tsx/esm src/db/migrate.ts",
    "db:seed": "node --import tsx/esm src/db/seed.ts"
  },
  "dependencies": {
    "@wandr/shared": "*",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "pg": "^8.12.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0",
    "node-fetch": "^3.3.2",
    "pino": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0",
    "tsx": "^4.16.0"
  }
}
